# ╔══════════════════════════════════════════════════╗
# ║         LAWCTOPUS COURSE — Environment           ║
# ╚══════════════════════════════════════════════════╝
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
#
# Naming convention:
#   NEXT_PUBLIC_*  → exposed to the browser (safe for anon keys)
#   No prefix      → server-only (route handlers, server components)

# ─── Supabase ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only – NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── WhatsApp ─────────────────────────────────────
# International format, digits only (e.g. 918334961769)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Analytics (optional) ─────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Feature Flags (optional) ─────────────────────
# NEXT_PUBLIC_ENABLE_WAITLIST=true
